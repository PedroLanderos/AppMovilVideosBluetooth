<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cliente"
        android:textStyle="bold"
        android:textSize="24sp" />

    <TextView
        android:id="@+id/clientStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estado: desconectado"
        android:layout_marginTop="4dp" />

    <Spinner
        android:id="@+id/deviceSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/connectButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Conectar a servidor emparejado" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
        <EditText
            android:id="@+id/searchInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Buscar video o pegar URL" />
        <Button
            android:id="@+id/searchButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buscar" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/privateModeCheck"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Modo privado: no registrar historial" />

    <CheckBox
        android:id="@+id/audioOnlyCheck"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bajo consumo: audio / baja calidad" />

    <TextView
        android:id="@+id/bufferStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Buffer: 0%" />

    <VideoView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="8dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp">
        <LinearLayout
            android:id="@+id/resultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>
</LinearLayout>
