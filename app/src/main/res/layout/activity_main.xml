<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="?attr/screenBackgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="?attr/brandColor">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BT Video Player"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="?attr/onBrandColor" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tema actual"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:textColor="?attr/onBrandColor" />
    </LinearLayout>

    <Button
        android:id="@+id/serverButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dispositivo A - Servidor"
        android:layout_marginTop="32dp" />

    <Button
        android:id="@+id/clientButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dispositivo B - Cliente"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/colorThemeButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cambiar color: Guinda IPN"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/modeThemeButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cambiar claro/oscuro: Sistema"
        android:layout_marginTop="8dp" />
</LinearLayout>
